# Changing the password need to either
# manually udpate one in container or
# deleting all the data, it only used
# on first time database started

MYSQL_USER=app
MYSQL_PASSWORD=please_replace_me
MYSQL_DATABASE=EmployeeApp

# IF hosting own, make sure its same
# with one in composer.yml for hostname
# its docker alias
DATABASE_HOSTNAME=database
DATABASE_PORT=3306

# This password is used for root account
# for managing the database, if starts own
# database instead reusing existing one
MYSQL_ROOT_PASSWORD=please_replace_me_2

